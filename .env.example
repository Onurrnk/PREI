# PREI | Smart Suites — environment configuration
# Copy this file to `.env.local` and fill in real values.

# API base URL.
# - Leave EMPTY for local development: requests hit relative "/api/..."
#   and are intercepted by the MSW mock service worker.
# - In production, point to your real backend, e.g.:
#     VITE_API_BASE_URL=https://api.prei.app
#   or your Supabase Edge Functions / REST URL.
VITE_API_BASE_URL=

# --- Supabase (when wiring the real backend) ---
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
