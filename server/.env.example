# =====================================================================
# PREI Backend — ortam değişkenleri (G-2: gerçek .env ASLA commit edilmez)
# Kopyala: cp .env.example .env  ve değerleri doldur.
# =====================================================================

# --- Sunucu ---
PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# --- Postgres (Supabase) ---
# ÖNEMLİ (RLS): Üretimde RLS'in AKTİF kalması için NOBYPASSRLS bir role
# (ör. prei_app) bağlan — service_role/postgres DEĞİL. Faz 0'da geçici olarak
# pooler connection kullanılabilir; deploy'da prei_app rolüne geçilir.
# Supabase Dashboard > Project Settings > Database > Connection string (URI).
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.kkcvfvbjmohlplepadip.supabase.co:5432/postgres
DATABASE_SSL=true

# --- Supabase Auth (JWT doğrulama) ---
# Backend token'ı Supabase /auth/v1/user ile UZAKTAN doğrular (imza algoritmasından
# ve anahtar rotasyonundan bağımsız — secret gerektirmez). Gereken:
SUPABASE_URL=https://kkcvfvbjmohlplepadip.supabase.co
# anon/publishable key (Dashboard > Settings > API Keys > anon/publishable):
SUPABASE_ANON_KEY=
# Legacy HS256 secret (OPSİYONEL — verilirse hızlı lokal doğrulama; proje ES256'ya
# tam geçince JWKS lokal doğrulamaya evrilebilir):
SUPABASE_JWT_SECRET=
DEFAULT_TENANT_SLUG=produality

# --- Agent Ingest (n8n → POST /api/agent/whatsapp-event) ---
# n8n bu anahtarı X-Agent-Key header'ında gönderir (OV-4). Güçlü rastgele üret:
#   openssl rand -hex 32
AGENT_API_KEY=

# --- Google OAuth (Gmail API) ---
# Create these in Google Cloud Console (see GMAIL_SETUP.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an authorized redirect URI in your OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# --- DEBT-GMAIL-001 (Faz 1): token'lar şifreli Supabase Vault'a taşınacak ---
# Şimdilik InMemoryTokenStore (dev). Prod'da SUPABASE_VAULT ile TokenStore.
